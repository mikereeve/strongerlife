# Copy to .env.local for local development.
# Production values: Netlify → Site configuration → Environment variables
#   Site: strongerlife (757b5e8f-6437-4ab0-86aa-d20990eb6401)
#   https://app.netlify.com/sites/strongerlife/configuration/env

# --- Google Search Console (optional if using HTML file in public/) ---
# Meta-tag verification only. Use the token from GSC (not the full <meta> tag).
# Renders as: <meta name="google-site-verification" content="YOUR_TOKEN" />
# Alternative: deploy public/googleXXXXXXXX.html (see app/layout.tsx comments).
# NEXT_PUBLIC_GSC_VERIFICATION_ID=

# --- Google Analytics 4 (public site tag) ---
# Web stream Measurement ID (format G-XXXXXXXXXX). Baked in at build time.
# After changing in Netlify: Deploys → Trigger deploy → Deploy site.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- GA4 Data API (admin dashboard at /admin only) ---
# GA4_PROPERTY_ID=          # Numeric Property ID (Admin → Property settings)
# GA_CLIENT_EMAIL=          # service-account@....iam.gserviceaccount.com
# GA_PRIVATE_KEY=           # PEM private key; use \n for newlines in Netlify

# --- Sanity CMS ---
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
# NEXT_PUBLIC_SANITY_API_VERSION=2024-12-01
# SANITY_API_READ_TOKEN=

# --- Admin ---
# ADMIN_PASSWORD=
